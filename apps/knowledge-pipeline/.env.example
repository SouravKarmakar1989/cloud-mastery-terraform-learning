# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your actual API key.

# -----------------------------------------------------------------------
# OpenAI API (required for generate_blog.py)
# -----------------------------------------------------------------------

OPENAI_API_KEY=sk-...

# Model to use (optional, default: gpt-4o)
# Other options: gpt-4o-mini, gpt-4-turbo, o3-mini
OPENAI_MODEL=gpt-4o

# For local or alternative OpenAI-compatible APIs (optional):
#   Ollama:   OPENAI_BASE_URL=http://localhost:11434/v1
#   Groq:     OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   Together: OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_BASE_URL=
